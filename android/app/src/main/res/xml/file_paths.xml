<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- Restricted to a dedicated export subdirectory — NOT the entire files dir.
         This prevents the FileProvider from granting access to master.key,
         share data, or config files. -->
    <files-path name="miasma_exports" path="exports/" />
    <!-- External cache restricted to export subdirectory. -->
    <external-cache-path name="miasma_cache" path="exports/" />
</paths>
