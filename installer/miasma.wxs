<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX installer manifest for Miasma Protocol (Windows x64).
  See scripts/build-installer.ps1 for build instructions.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <!-- Version is injected at build time via -d Version=x.y.z -->
  <?define ProductVersion = "!(bind.property.Version)" ?>

  <Package
    Name="Miasma Protocol"
    Manufacturer="Miasma Contributors"
    Version="$(var.Version)"
    UpgradeCode="E8A3F0C1-7B2D-4E56-9A1F-3C8D5E7F0B12"
    Scope="perMachine"
    InstallerVersion="500"
    Language="1033"
    Codepage="1252">

    <SummaryInformation
      Description="Miasma Protocol — content-addressed encrypted storage with P2P distribution"
      Manufacturer="Miasma Contributors" />

    <!-- Embed cabinet into MSI for single-file distribution. -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Runtime prerequisite check: MSVC 2015-2022 redistributable (vcruntime140.dll). -->
    <Launch Condition="Installed OR VCRUNTIME140"
            Message="Miasma requires the Microsoft Visual C++ 2015-2022 Redistributable (x64). Download it from: https://aka.ms/vs/17/release/vc_redist.x64.exe" />
    <Property Id="VCRUNTIME140">
      <DirectorySearch Id="VCRuntimeSearch" Path="[SystemFolder]">
        <FileSearch Name="vcruntime140.dll" />
      </DirectorySearch>
    </Property>

    <!-- Major upgrade: remove older versions automatically. -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Miasma is already installed."
      Schedule="afterInstallInitialize" />

    <!-- Single feature: all binaries + docs + shell integration. -->
    <Feature Id="MainFeature" Title="Miasma Protocol" Level="1">
      <ComponentGroupRef Id="Binaries" />
      <ComponentGroupRef Id="Docs" />
      <ComponentGroupRef Id="Shortcuts" />
      <ComponentRef Id="PathEnvComponent" />
      <ComponentRef Id="MagnetProtocol" />
      <ComponentRef Id="TorrentOpenWith" />
    </Feature>

    <!-- UI: WiX built-in install dir dialog with license. -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="installer\license.rtf" />

    <!-- ── Directory layout ──────────────────────────────────────── -->

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Miasma Protocol">
        <Directory Id="DocsFolder" Name="docs" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="MiasmaMenuFolder" Name="Miasma Protocol" />
    </StandardDirectory>

    <!-- ── Binaries ──────────────────────────────────────────────── -->

    <ComponentGroup Id="Binaries" Directory="INSTALLFOLDER">
      <Component Id="MiasmaDesktopExe" Bitness="always64" Guid="A1B2C3D4-0001-4000-8000-000000000001">
        <File Id="miasma_desktop.exe"
              Source="$(var.BinDir)\miasma-desktop.exe"
              KeyPath="yes" />
      </Component>

      <Component Id="MiasmaCliExe" Bitness="always64" Guid="A1B2C3D4-0001-4000-8000-000000000002">
        <File Id="miasma.exe"
              Source="$(var.BinDir)\miasma.exe"
              KeyPath="yes" />
      </Component>

      <Component Id="MiasmaBridgeExe" Bitness="always64" Guid="A1B2C3D4-0001-4000-8000-000000000003">
        <File Id="miasma_bridge.exe"
              Source="$(var.BinDir)\miasma-bridge.exe"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── Documentation ─────────────────────────────────────────── -->

    <ComponentGroup Id="Docs" Directory="DocsFolder">
      <Component Id="ReadmeTxt" Bitness="always64" Guid="A1B2C3D4-0001-4000-8000-000000000010">
        <File Id="README.txt"
              Name="README.txt"
              Source="installer\README-installed.txt"
              KeyPath="yes" />
      </Component>

      <Component Id="ReleaseNotes" Bitness="always64" Guid="A1B2C3D4-0001-4000-8000-000000000011">
        <File Id="RELEASE_NOTES.md"
              Source="RELEASE-NOTES.md"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── Start Menu shortcuts ──────────────────────────────────── -->

    <ComponentGroup Id="Shortcuts" Directory="MiasmaMenuFolder">
      <!-- Primary shortcut: Easy mode (for non-technical users) -->
      <Component Id="DesktopShortcut" Guid="A1B2C3D4-0001-4000-8000-000000000020">
        <Shortcut Id="MiasmaDesktopShortcut"
                  Name="Miasma"
                  Description="Miasma — save and retrieve content securely"
                  Target="[INSTALLFOLDER]miasma-desktop.exe"
                  Arguments="--mode easy"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveMiasmaMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\Miasma Protocol"
                       Name="MenuInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>

      <!-- Technical shortcut: full diagnostics (for developers/testers) -->
      <Component Id="TechnicalShortcut" Guid="A1B2C3D4-0001-4000-8000-000000000022">
        <Shortcut Id="MiasmaTechnicalShortcut"
                  Name="Miasma Technical"
                  Description="Miasma Technical Beta — full diagnostics and protocol visibility"
                  Target="[INSTALLFOLDER]miasma-desktop.exe"
                  Arguments="--mode technical"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\Miasma Protocol"
                       Name="TechnicalMenuInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>

      <!-- CLI shortcut: command prompt with Miasma on PATH -->
      <Component Id="CliShortcut" Guid="A1B2C3D4-0001-4000-8000-000000000021">
        <Shortcut Id="MiasmaCliShortcut"
                  Name="Miasma CLI"
                  Description="Open a command prompt with Miasma on PATH"
                  Target="[SystemFolder]cmd.exe"
                  Arguments='/k "set PATH=[INSTALLFOLDER];%PATH% &amp; echo Miasma CLI ready. Type: miasma --help"'
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\Miasma Protocol"
                       Name="CliMenuInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── PATH environment variable ────────────────────────────── -->

    <Component Id="PathEnvComponent" Directory="INSTALLFOLDER"
               Bitness="always64" Guid="A1B2C3D4-0001-4000-8000-000000000030">
      <Environment Id="MiasmaPath"
                   Name="PATH"
                   Value="[INSTALLFOLDER]"
                   Permanent="no"
                   Part="last"
                   Action="set"
                   System="yes" />
      <RegistryValue Root="HKLM"
                     Key="Software\Miasma Protocol"
                     Name="PathSet"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <!-- ── magnet: protocol handler ────────────────────────────── -->
    <!--
      Registers Miasma as an available handler for magnet: URIs.
      Windows will offer Miasma as an option when a user clicks a magnet link.
      The user must explicitly choose Miasma in "Default apps" or the first-use
      prompt; the installer does not forcibly take over the association.
    -->
    <Component Id="MagnetProtocol" Directory="INSTALLFOLDER"
               Bitness="always64" Guid="A1B2C3D4-0001-4000-8000-000000000040">
      <RegistryValue Root="HKLM"
                     Key="Software\Classes\Miasma.Magnet"
                     Type="string"
                     Value="Miasma Magnet Link" />
      <RegistryValue Root="HKLM"
                     Key="Software\Classes\Miasma.Magnet"
                     Name="URL Protocol"
                     Type="string"
                     Value="" />
      <RegistryValue Root="HKLM"
                     Key="Software\Classes\Miasma.Magnet\DefaultIcon"
                     Type="string"
                     Value="[INSTALLFOLDER]miasma-desktop.exe,0" />
      <RegistryValue Root="HKLM"
                     Key="Software\Classes\Miasma.Magnet\shell\open\command"
                     Type="string"
                     Value="&quot;[INSTALLFOLDER]miasma-desktop.exe&quot; &quot;%1&quot;" />
      <!-- Register as a capable handler so Windows offers the choice. -->
      <RegistryValue Root="HKLM"
                     Key="Software\Miasma Protocol\Capabilities\URLAssociations"
                     Name="magnet"
                     Type="string"
                     Value="Miasma.Magnet" />
      <RegistryValue Root="HKLM"
                     Key="Software\Miasma Protocol\Capabilities"
                     Name="ApplicationName"
                     Type="string"
                     Value="Miasma" />
      <RegistryValue Root="HKLM"
                     Key="Software\Miasma Protocol\Capabilities"
                     Name="ApplicationDescription"
                     Type="string"
                     Value="Import magnet links into Miasma encrypted storage" />
      <RegistryValue Root="HKLM"
                     Key="Software\RegisteredApplications"
                     Name="Miasma"
                     Type="string"
                     Value="Software\Miasma Protocol\Capabilities"
                     KeyPath="yes" />
    </Component>

    <!-- ── .torrent file open-with (non-aggressive) ──────────── -->
    <!--
      Registers Miasma in the "Open with" list for .torrent files.
      Uses OpenWithProgids so existing torrent client associations are NOT
      overridden. The user sees Miasma as one option among others.
    -->
    <Component Id="TorrentOpenWith" Directory="INSTALLFOLDER"
               Bitness="always64" Guid="A1B2C3D4-0001-4000-8000-000000000041">
      <RegistryValue Root="HKLM"
                     Key="Software\Classes\Miasma.TorrentFile"
                     Type="string"
                     Value="Miasma Torrent Import" />
      <RegistryValue Root="HKLM"
                     Key="Software\Classes\Miasma.TorrentFile\DefaultIcon"
                     Type="string"
                     Value="[INSTALLFOLDER]miasma-desktop.exe,0" />
      <RegistryValue Root="HKLM"
                     Key="Software\Classes\Miasma.TorrentFile\shell\open\command"
                     Type="string"
                     Value="&quot;[INSTALLFOLDER]miasma-desktop.exe&quot; &quot;%1&quot;" />
      <!-- OpenWithProgids — adds to "Open with" without hijacking default. -->
      <RegistryValue Root="HKLM"
                     Key="Software\Classes\.torrent\OpenWithProgids"
                     Name="Miasma.TorrentFile"
                     Type="string"
                     Value=""
                     KeyPath="yes" />
      <!-- Also register in Capabilities for modern Settings app. -->
      <RegistryValue Root="HKLM"
                     Key="Software\Miasma Protocol\Capabilities\FileAssociations"
                     Name=".torrent"
                     Type="string"
                     Value="Miasma.TorrentFile" />
    </Component>

  </Package>
</Wix>
