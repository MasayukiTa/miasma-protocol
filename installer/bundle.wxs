<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX Bundle (bootstrapper) for Miasma Protocol.
  Produces a single MiasmaSetup.exe that:
    1. Detects and installs the VC++ 2015-2022 Redistributable (x64) if needed
    2. Installs the Miasma MSI

  Build: see scripts/build-installer.ps1
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle
    Name="Miasma Protocol"
    Manufacturer="Miasma Contributors"
    Version="$(var.Version)"
    UpgradeCode="F9B4A1D2-8C3E-4F67-AB12-6D9E0F1A2B34"
    DisableModify="yes">

    <!-- Detect VC++ 2015-2022 Redistributable (x64) via registry. -->
    <util:RegistrySearch
      Id="VCRedistSearch"
      Root="HKLM"
      Key="SOFTWARE\Microsoft\VisualStudio\14.0\VC\Runtimes\X64"
      Value="Installed"
      Variable="VCRedistInstalled"
      Result="value" />

    <!-- Standard bootstrapper UI. -->
    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
        LicenseUrl=""
        Theme="hyperlinkLicense" />
    </BootstrapperApplication>

    <Chain>
      <!-- VC++ 2015-2022 Redistributable (x64).
           Only installed when not already present.
           Permanent=yes: not removed on Miasma uninstall (shared system component). -->
      <ExePackage
        Id="VCRedist"
        Name="Microsoft Visual C++ 2015-2022 Redistributable (x64)"
        SourceFile="$(var.VCRedistPath)"
        InstallArguments="/install /quiet /norestart"
        RepairArguments="/repair /quiet /norestart"
        DetectCondition="VCRedistInstalled"
        Vital="yes"
        Permanent="yes"
        Compressed="yes">

        <!-- 3010 = reboot required, 1638 = another version installed, 5100 = system requirements not met (already present) -->
        <ExitCode Value="3010" Behavior="forceReboot" />
        <ExitCode Value="1638" Behavior="success" />
        <ExitCode Value="5100" Behavior="success" />
      </ExePackage>

      <!-- Miasma MSI (embedded in the bundle). -->
      <MsiPackage
        Id="MiasmaMsi"
        SourceFile="$(var.MsiPath)"
        Vital="yes" />
    </Chain>

  </Bundle>
</Wix>
